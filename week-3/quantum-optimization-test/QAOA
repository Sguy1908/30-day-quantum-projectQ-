from qiskit_algorithms import QAOA 
from qiskit_algorithms.optimizers import COBYLA
from qiskit.primitives import StatevectorSampler
from qiskit_optimization.applications import Maxcut
from qiskit_optimization.translators import to_ising
import networkx as nx 

#  QAOA - the quantum optimization algorithm. 
# COBYLA - a classical optimizer that updates the circuit parameters. 
# StatevectorSampler - executes the quantum circuit. 
# MaxCut - converts a graph optimization problem into a quantum-friendly format. 
# NetworkX - creates the graph used in the optimization problem. 

graph = nx.Graph()
graph.add_edges_from([     (0,1),     (1,2),     (2,3),     (3,0) ]) 

maxcut = Maxcut(graph) #ising hamiltonian for the maxcut problem.
qp = maxcut.to_quadratic_program()
operator, offset = to_ising(qp) 

optimizer = COBYLA(maxiter=100) 

#QAOA algorithm ->
sampler = StatevectorSampler()
qaoa = QAOA(sampler=sampler, #run circuit
            optimizer=optimizer,    #improve paramters
            reps=2 ) #alternating layers of QAOA

#Solving ->
result = qaoa.compute_minimum_eigenvalue(operator)
print(result) 

